# Supabase — anonymous leaderboard backend.
# Copy this file to ".env" and fill in the values from your Supabase project
# (Project Settings → API). Leave them blank to use the seeded fallback board.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe — payments.
# Get your publishable key from https://dashboard.stripe.com/apikeys
# Use the test key (pk_test_...) during development.
VITE_STRIPE_PUBLISHABLE_KEY=
